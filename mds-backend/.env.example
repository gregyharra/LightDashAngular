# App metadata database (PostgreSQL). Use sqlite+pysqlite:///:memory: for ephemeral tests.
DATABASE_URL=postgresql+psycopg2://mds:mds@localhost:5432/mds

# Comma-separated list of allowed browser origins (Angular dev server by default).
CORS_ORIGINS=http://localhost:4200

# Tables are always created on startup; set to true only to insert demo rows automatically.
# Or run manually: python -m mds.scripts.seed_demo
SEED_DEMO_DATA=false

# Local dbt project (no Git). Use an absolute path or path relative to mds-backend/.
DBT_PROJECT_PATH=../mds-transform

# Optional: override where manifest.json / catalog.json live (default: {DBT_PROJECT_PATH}/target)
# DBT_ARTIFACTS_PATH=/path/to/dbt/target

# When true, regenerate manifest.json from project sources when stale (before semantic reads, after Git sync).
# Refresh endpoint always checks staleness regardless of this flag.
# AUTO_REGENERATE_MANIFEST=true

# Local directory for cloned project Git repositories (one folder per project UUID).
PROJECTS_DATA_DIR=.data/projects

# Fernet key for encrypting warehouse connection passwords at rest.
# Optional for local development — a fixed dev key is used when unset (see startup log warning).
# Required in production. Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ENCRYPTION_KEY=

# Log compiled warehouse SQL to the backend terminal before Trino execution.
# LOG_SQL_QUERIES=true
